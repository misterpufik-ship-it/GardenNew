Options -MultiViews

<IfModule mod_dir.c>
    DirectorySlash Off
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # HTTP -> HTTPS
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # www -> без www
    RewriteCond %{HTTP_HOST} ^www\.garden-lounge\.pro$ [NC]
    RewriteRule ^ https://garden-lounge.pro%{REQUEST_URI} [R=301,L]

    # CouchCMS admin
    RewriteCond %{THE_REQUEST} \s/+udelnaya/couch[\s?] [NC]
    RewriteRule ^ /admiralteyskaya/couch/index.php [L]

    # BeGet: физическая папка /admiralteyskaya/couch без слэша → 403
    RewriteCond %{THE_REQUEST} \s/+admiralteyskaya/couch[\s?] [NC]
    RewriteRule ^ https://garden-lounge.pro/admiralteyskaya/couch/ [R=301,L]

    # Убрать слэш только в конце URL (кроме главной / и CouchCMS admin)
    RewriteCond %{REQUEST_URI} !^/(admiralteyskaya|udelnaya)/couch/$
    RewriteCond %{REQUEST_URI} ^(.+)/$
    RewriteRule ^ https://%{HTTP_HOST}%1 [R=301,L]

    # Страницы-папки без слэша -> index.php
    RewriteCond %{REQUEST_URI} ^/admiralteyskaya$
    RewriteRule ^ /admiralteyskaya/index.php [L]

    RewriteCond %{REQUEST_URI} ^/udelnaya$
    RewriteRule ^ /udelnaya/index.php [L]

    RewriteCond %{REQUEST_URI} ^/admiralteyskaya/menu$
    RewriteRule ^ /admiralteyskaya/menu/index.php [L]

    RewriteCond %{REQUEST_URI} ^/admiralteyskaya/menu/text$
    RewriteRule ^ /admiralteyskaya/menu/text/index.php [L]

    RewriteCond %{REQUEST_URI} ^/admiralteyskaya/menu/visual$
    RewriteRule ^ /admiralteyskaya/menu/visual/index.php [L]

    RewriteCond %{REQUEST_URI} ^/admiralteyskaya/menu/english$
    RewriteRule ^ /admiralteyskaya/menu/english/index.php [L]

    RewriteCond %{REQUEST_URI} ^/udelnaya/menu$
    RewriteRule ^ /udelnaya/menu/index.php [L]

    RewriteCond %{REQUEST_URI} ^/udelnaya/menu/text$
    RewriteRule ^ /udelnaya/menu/text/index.php [L]

    RewriteCond %{REQUEST_URI} ^/udelnaya/menu/visual$
    RewriteRule ^ /udelnaya/menu/visual/index.php [L]

    RewriteCond %{REQUEST_URI} ^/udelnaya/menu/english$
    RewriteRule ^ /udelnaya/menu/english/index.php [L]

    RewriteRule ^$ admiralteyskaya/site-home.php [L]

    RewriteRule ^udelnaya/couch/uploads/(.*)$ /admiralteyskaya/couch/uploads/$1 [L]

    # Legacy duplicate paths
    RewriteRule ^admiralteyskaya/udelnaya/menu/?(.*)$ https://garden-lounge.pro/udelnaya/menu/$1 [R=301,L]
    RewriteRule ^admiralteyskaya/udelnaya/?(.*)$ https://garden-lounge.pro/udelnaya/$1 [R=301,L]
    RewriteRule ^menu/?(.*)$ https://garden-lounge.pro/admiralteyskaya/menu/$1 [R=301,L]

    # Legacy broken server-path URLs
    RewriteRule ^home/m/mrpuffch/garden-lounge\.pro/public_html/admiralteyskaya/menu/?$ https://garden-lounge.pro/admiralteyskaya/menu [R=301,L]
    RewriteRule ^home/m/mrpuffch/garden-lounge\.pro/public_html/udelnaya/menu/?$ https://garden-lounge.pro/udelnaya/menu [R=301,L]
    RewriteRule ^home/m/mrpuffch/garden-lounge\.pro/public_html/admiralteyskaya/menu/(.*)$ https://garden-lounge.pro/admiralteyskaya/menu/$1 [R=301,L]
    RewriteRule ^home/m/mrpuffch/garden-lounge\.pro/public_html/udelnaya/menu/(.*)$ https://garden-lounge.pro/udelnaya/menu/$1 [R=301,L]

    RewriteCond %{HTTP:Accept} image/webp
    RewriteCond %{DOCUMENT_ROOT}/$1.webp -f
    RewriteRule ^(.+)\.(jpe?g|png)$ $1.webp [T=image/webp,L]
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/html "access plus 5 minutes"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType video/mp4 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

    <FilesMatch "^favicon\.(png|ico)$">
        Header set Cache-Control "public, max-age=604800, must-revalidate"
    </FilesMatch>
    <FilesMatch "\.(css|js|mjs|webp|avif|jpg|jpeg|png|gif|svg|ico|woff2|mp4)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>
